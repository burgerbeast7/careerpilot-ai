# Project Settings
PROJECT_NAME="CareerPilot AI (Enterprise Edition)"

# Security Settings
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY="replace-this-with-a-real-secure-random-hex-string"
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days

# Database Settings
# Default is SQLite for easy local launch. Switch to PostgreSQL for production.
DATABASE_URL="sqlite:///./careerpilot.db"
# DATABASE_URL="postgresql://username:password@localhost:5432/careerpilot_db"

# AI Provider Selection
# Supports: "mock", "openai", "gemini", "watsonx", "groq"
AI_PROVIDER="mock"

# OpenAI Credentials
OPENAI_API_KEY=""

# Google Gemini Credentials
GEMINI_API_KEY=""

# IBM watsonx Credentials
WATSONX_API_KEY=""
WATSONX_PROJECT_ID=""
WATSONX_URL="https://us-south.ml.cloud.ibm.com"

# Groq Credentials
GROQ_API_KEY=""
